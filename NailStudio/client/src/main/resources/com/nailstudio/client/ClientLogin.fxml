<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nailstudio.client.ClientLoginController">
    <children>
        <!-- ФОН -->
        <ImageView pickOnBounds="true" preserveRatio="false">
            <image><Image url="@background.jpg" /></image>
        </ImageView>

        <!-- ИНТЕРФЕЙС -->
        <VBox alignment="CENTER" spacing="25.0" style="-fx-background-color: transparent;">
            <padding><Insets bottom="40.0" left="40.0" right="40.0" top="40.0" /></padding>
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Вход или регистрация" textAlignment="CENTER" style="-fx-fill: #8B1538;">
                    <font><Font name="System Bold" size="28.0" /></font>
                </Text>

                <Label text="Номер телефона" style="-fx-text-fill: #8B1538;"><font><Font size="16.0" /></font></Label>
                <TextField fx:id="phoneField" prefHeight="50.0" prefWidth="280.0" style="-fx-background-color: #F5F9FC; -fx-background-radius: 25; -fx-background-insets: 0; -fx-border-color: #8B1538; -fx-border-width: 2; -fx-border-radius: 25; -fx-padding: 10 15 10 15; -fx-font-size: 16;" />

                <HBox spacing="20.0" alignment="CENTER" style="-fx-background-color: transparent;">
                    <children>
                        <Button fx:id="loginBtn" mnemonicParsing="false" onAction="#handleLogin" prefHeight="50.0" prefWidth="180.0"
                                style="-fx-background-color: #F5F9FC; -fx-background-radius: 25; -fx-background-insets: 0;
                                 -fx-border-color: #8B1538; -fx-border-width: 2; -fx-border-radius: 25;
                                 -fx-text-fill: #8B1538; -fx-font-size: 16; -fx-font-weight: bold;
                                 -fx-cursor: hand; -fx-padding: 10 24 10 24;"
                                text="Войти" />
                        <Button fx:id="registerBtn" mnemonicParsing="false" onAction="#handleRegister" prefHeight="50.0" prefWidth="180.0"
                                style="-fx-background-color: #F5F9FC; -fx-background-radius: 25; -fx-background-insets: 0;
                                 -fx-border-color: #8B1538; -fx-border-width: 2; -fx-border-radius: 25;
                                 -fx-text-fill: #8B1538; -fx-font-size: 16; -fx-font-weight: bold;
                                 -fx-cursor: hand; -fx-padding: 10 24 10 24;"
                                text="Регистрация" />
                    </children>
                </HBox>
            </children>
        </VBox>
    </children>
</StackPane>