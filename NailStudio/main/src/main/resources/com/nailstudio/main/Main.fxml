<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<StackPane xmlns="http://javafx.com/javafx/22" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nailstudio.main.MainController">
    <children>

        <!-- СЛОЙ 1: ФОНОВАЯ КАРТИНКА -->
        <ImageView fitHeight="1000.0" fitWidth="1000.0" pickOnBounds="true" preserveRatio="false">
            <image>
                <Image url="@background.jpg" />
            </image>
        </ImageView>

        <!-- СЛОЙ 2: ИНТЕРФЕЙС -->
        <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: transparent;">
            <children>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Добро пожаловать!" textAlignment="CENTER" wrappingWidth="400.0" style="-fx-fill: #8B1538;">
                    <font>
                        <Font name="System Bold" size="32.0" />
                    </font>
                </Text>
                <Text strokeType="OUTSIDE" strokeWidth="0.0" text="Как хотите войти?" textAlignment="CENTER" wrappingWidth="400.0" style="-fx-fill: #8B1538;">
                    <font>
                        <Font size="24.0" />
                    </font>
                </Text>

                <!-- Кнопка Клиент -->
                <Button fx:id="clientBtn" mnemonicParsing="false" onAction="#handleClientClick" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: #F5F9FC; -fx-background-radius: 25; -fx-background-insets: 0;
                           -fx-border-color: #8B1538; -fx-border-width: 2; -fx-border-radius: 25;
                           -fx-text-fill: #8B1538; -fx-font-size: 16; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 24 10 24;"
                        text="Клиент" />

                <!-- Кнопка Администратор -->
                <Button fx:id="adminBtn" mnemonicParsing="false" onAction="#handleAdminClick" prefHeight="50.0" prefWidth="220.0"
                        style="-fx-background-color: #F5F9FC; -fx-background-radius: 25; -fx-background-insets: 0;
                           -fx-border-color: #8B1538; -fx-border-width: 2; -fx-border-radius: 25;
                           -fx-text-fill: #8B1538; -fx-font-size: 16; -fx-font-weight: bold;
                           -fx-cursor: hand; -fx-padding: 10 24 10 24;"
                        text="Администратор" />
            </children>
            <padding>
                <Insets bottom="40.0" left="40.0" right="40.0" top="40.0" />
            </padding>
        </VBox>
    </children>
</StackPane>